<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<title>Setbook — Client Training Ledger</title>
<meta name="description" content="Setbook: a self-contained client management app for personal trainers — profiles, diet plans, workout programs, and progress tracking, with a matching client portal." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap">
<style>
  :root {
    --ink: #15191B;
    --panel: #1E2523;
    --panel-2: #242B29;
    --line: #2C3432;
    --chalk: #EDEFE9;
    --muted: #8B9A94;
    --accent: #D9A441;
    --veg: #3FA34D;
    --nonveg: #A13D2C;
    --egg: #9C7A2E;
    --danger: #C0503D;
  }
  html, body { height: 100%; margin: 0; }
  body { font-family: 'Inter', sans-serif; background: var(--ink); color: var(--chalk); }
  #root { min-height: 100vh; }
  *, *::before, *::after { box-sizing: border-box; }
  ::selection { background: var(--accent); color: var(--ink); }

  .sb-display { font-family: 'Barlow Condensed', sans-serif; text-transform: uppercase; letter-spacing: 0.03em; font-weight: 700; }
  .sb-mono { font-family: 'IBM Plex Mono', monospace; }

  .sb-btn {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 13px; border-radius: 3px;
    padding: 9px 16px; border: 1px solid var(--line); background: var(--panel-2); color: var(--chalk);
    cursor: pointer; transition: border-color 0.15s, background 0.15s;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .sb-btn:hover { border-color: var(--muted); }
  .sb-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .sb-btn-primary { background: var(--accent); border-color: var(--accent); color: #1A1503; }
  .sb-btn-primary:hover { filter: brightness(1.08); }
  .sb-btn-danger { color: #F0B4A6; border-color: var(--danger); background: transparent; }
  .sb-btn-danger:hover { background: rgba(192,80,61,0.15); }
  .sb-btn-ghost { background: transparent; border-color: transparent; }
  .sb-btn-ghost:hover { border-color: var(--line); }
  .sb-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .sb-icon-btn { padding: 8px; border-radius: 50%; }

  .sb-input, .sb-select, .sb-textarea {
    font-family: 'Inter', sans-serif; font-size: 13.5px; background: var(--ink);
    border: 1px solid var(--line); color: var(--chalk); border-radius: 3px; padding: 9px 10px; width: 100%;
  }
  .sb-input:focus, .sb-select:focus, .sb-textarea:focus { outline: none; border-color: var(--accent); }
  .sb-textarea { resize: vertical; min-height: 70px; line-height: 1.5; }
  .sb-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); font-weight: 600; margin-bottom: 6px; display: block; }
  .sb-field { margin-bottom: 14px; }

  .sb-panel { background: var(--panel); border: 1px solid var(--line); border-radius: 6px; }
  .sb-card { background: var(--panel-2); border: 1px solid var(--line); border-radius: 5px; padding: 16px; }

  .sb-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .sb-grid6 { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 10px; }
  @media (max-width: 680px) {
    .sb-grid2 { grid-template-columns: 1fr; }
    .sb-grid6 { grid-template-columns: repeat(2, 1fr); }
  }

  .sb-tabbar { display: flex; border-bottom: 1px solid var(--line); overflow-x: auto; }
  .sb-tab {
    display: flex; align-items: center; gap: 6px; white-space: nowrap; padding: 10px 14px;
    font-size: 13px; font-weight: 600; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent;
    background: transparent; border-top: none; border-left: none; border-right: none;
  }
  .sb-tab:hover { color: var(--chalk); }
  .sb-tab-active { color: var(--chalk); border-bottom-color: var(--accent); }

  .sb-swipe-viewport { overflow-x: hidden; overflow-y: visible; width: 100%; touch-action: pan-y; }
  .sb-swipe-track { display: flex; transition: transform 0.28s cubic-bezier(.22,.68,0,1); }
  .sb-swipe-slide { flex-shrink: 0; min-width: 0; padding-top: 18px; }
  .sb-dots { display: none; justify-content: center; gap: 6px; margin-top: 14px; }
  .sb-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--line); }
  .sb-dot-active { background: var(--accent); width: 16px; border-radius: 3px; transition: all 0.2s; }
  @media (max-width: 680px) { .sb-dots { display: flex; } }

  .sb-mark { display: inline-block; width: 13px; height: 13px; border-radius: 2px; position: relative; flex-shrink: 0; }
  .sb-mark::after { content: ''; position: absolute; inset: 3px; border-radius: 50%; background: var(--dot-color); }

  .sb-client-row { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 4px; cursor: pointer; border: 1px solid transparent; }
  .sb-client-row:hover { background: var(--panel-2); }
  .sb-client-row-active { background: var(--panel-2); border-color: var(--line); }

  .sb-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
  .sb-scrollbar::-webkit-scrollbar-thumb { background: var(--line); border-radius: 4px; }
  .sb-scrollbar::-webkit-scrollbar-track { background: transparent; }

  .sb-table-wrap { overflow-x: auto; }
  .sb-table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 420px; }
  .sb-table th { text-align: left; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); font-weight: 600; padding: 8px 10px; border-bottom: 1px solid var(--line); }
  .sb-table td { padding: 9px 10px; border-bottom: 1px solid var(--line); }
  .sb-table tr:last-child td { border-bottom: none; }

  .sb-progress-track { height: 6px; background: var(--line); border-radius: 3px; overflow: hidden; }
  .sb-progress-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s; }

  .sb-empty { text-align: center; padding: 40px 20px; color: var(--muted); font-size: 13.5px; }
  .sb-badge { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; padding: 2px 7px; border-radius: 3px; border: 1px solid var(--line); color: var(--muted); }

  .sb-fab {
    position: absolute; right: 18px; bottom: 18px; width: 54px; height: 54px; border-radius: 50%;
    background: var(--accent); color: #1A1503; border: none; display: flex; align-items: center;
    justify-content: center; box-shadow: 0 6px 18px rgba(0,0,0,0.4); cursor: pointer; z-index: 15;
  }
  .sb-sheet-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); z-index: 20; display: flex; align-items: flex-end; }
  .sb-sheet { width: 100%; background: var(--panel); border-top: 1px solid var(--line); border-radius: 14px 14px 0 0; padding: 18px 18px 22px; max-height: 80%; overflow-y: auto; }
  .sb-sheet-handle { width: 36px; height: 4px; background: var(--line); border-radius: 2px; margin: 0 auto 14px; }

  .sb-mobile-header {
    position: sticky; top: 0; z-index: 5; background: var(--ink); border-bottom: 1px solid var(--line);
    padding: 14px 16px; display: flex; align-items: center; gap: 10px;
  }
</style>
</head>
<body>
<div id="root"></div>
